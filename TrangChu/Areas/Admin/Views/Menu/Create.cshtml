@using TrangChu.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@model Menu

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h2>Add a menu item</h2>
    </div>
    
    <section class="section">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Add a menu item</h5>
                        
                        <form method="Post" asp-area="Admin" asp-controller="Menu" asp-action="Create">
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Menu name</label>
                                <div class="col-sm-10">
                                    <input type="text" class="form-control" asp-for="Name" placeholder="Menu name..." />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Levels</label>
                                <div class="col-sm-10">
                                    <input type="number" class="form-control" id="Levels" name="Levels" value="1" readonly />
                                    <small class="form-text text-muted">Levels will be automatically calculated based on ParentID</small>
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">ParentID</label>
                                <div class="col-sm-10">
                                    <select asp-for="ParentID" class="form-select" asp-items="@(new SelectList(ViewBag.mnList, "Value", "Text"))" id="ParentID">
                                    </select>
                                    <span asp-validation-for="ParentID" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Link</label>
                                <div class="col-sm-10">
                                    <input type="text" class="form-control" asp-for="Url" placeholder="Enter the link..." />
                                    <span asp-validation-for="Url" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Menu order</label>
                                <div class="col-sm-10">
                                    <input type="number" class="form-control" asp-for="OrderIndex" value="0" />
                                    <span asp-validation-for="OrderIndex" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Position</label>
                                <div class="col-sm-10">
                                    <input type="number" class="form-control" id="Position" name="Position" value="1" />
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <label class="col-sm-2 col-form-label">Visible</label>
                                <div class="col-sm-10">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="Visible" name="Visible" checked />
                                        <label class="form-check-label" for="Visible">
                                            Visible
                                        </label>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-sm-10 offset-sm-2">
                                    <a asp-area="Admin" asp-controller="Menu" asp-action="Index" class="btn btn-warning">
                                        <i class="bi bi-arrow-left-circle"></i> Go back
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-save"></i> Save information
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Auto-update Levels based on ParentID
        document.getElementById('ParentID').addEventListener('change', function() {
            var parentId = this.value;
            var levelsInput = document.getElementById('Levels');
            if (parentId === '' || parentId === '0') {
                levelsInput.value = '1';
            } else {
                levelsInput.value = '2';
            }
        });
    </script>
}
