@using TrangChu.Areas.Admin.Models
@model AdminMenu

<main id="main" class="main">
    <div class="pagetitle">
        <h2>Thêm menu mới</h2>
    </div>

    <section class="section">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body mt-4">
                        <form asp-area="Admin" asp-controller="Menu" asp-action="Create" method="post">
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                            
                            <div class="row mb-3">
                                <label asp-for="ItemName" class="col-sm-2 col-form-label">Tên menu</label>
                                <div class="col-sm-10">
                                    <input asp-for="ItemName" class="form-control" />
                                    <span asp-validation-for="ItemName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="ControllerName" class="col-sm-2 col-form-label">Controller</label>
                                <div class="col-sm-10">
                                    <input asp-for="ControllerName" class="form-control" />
                                    <span asp-validation-for="ControllerName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="ActionName" class="col-sm-2 col-form-label">Action</label>
                                <div class="col-sm-10">
                                    <input asp-for="ActionName" class="form-control" />
                                    <span asp-validation-for="ActionName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="AreaName" class="col-sm-2 col-form-label">Area</label>
                                <div class="col-sm-10">
                                    <input asp-for="AreaName" class="form-control" />
                                    <span asp-validation-for="AreaName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="ItemLevel" class="col-sm-2 col-form-label">Cấp độ</label>
                                <div class="col-sm-10">
                                    <input asp-for="ItemLevel" class="form-control" type="number" />
                                    <span asp-validation-for="ItemLevel" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="ItemOrder" class="col-sm-2 col-form-label">Thứ tự</label>
                                <div class="col-sm-10">
                                    <input asp-for="ItemOrder" class="form-control" type="number" />
                                    <span asp-validation-for="ItemOrder" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="Icon" class="col-sm-2 col-form-label">Icon (Bootstrap Icon)</label>
                                <div class="col-sm-10">
                                    <input asp-for="Icon" class="form-control" placeholder="bi-house" />
                                    <span asp-validation-for="Icon" class="text-danger"></span>
                                    <small class="form-text text-muted">Ví dụ: bi-house, bi-grid, bi-person</small>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="IdName" class="col-sm-2 col-form-label">ID Name</label>
                                <div class="col-sm-10">
                                    <input asp-for="IdName" class="form-control" />
                                    <span asp-validation-for="IdName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="ItemTarget" class="col-sm-2 col-form-label">Target</label>
                                <div class="col-sm-10">
                                    <input asp-for="ItemTarget" class="form-control" placeholder="_self, _blank" />
                                    <span asp-validation-for="ItemTarget" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label asp-for="IsActive" class="col-sm-2 col-form-label">Kích hoạt</label>
                                <div class="col-sm-10">
                                    <div class="form-check">
                                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                        <label class="form-check-label" asp-for="IsActive">
                                            Hiển thị menu này
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-10 offset-sm-2">
                                    <button type="submit" class="btn btn-success">
                                        <i class="bi bi-check-circle me-1"></i>Lưu
                                    </button>
                                    <a asp-area="Admin" asp-controller="Menu" asp-action="Index" class="btn btn-secondary">
                                        <i class="bi bi-x-circle me-1"></i>Hủy
                                    </a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

