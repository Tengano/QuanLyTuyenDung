@using TrangChu.Areas.Admin.Models
@model AdminMenu

<main id="main" class="main">
    <div class="pagetitle">
        <h2>Xóa menu</h2>
    </div>

    <section class="section">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body mt-4">
                        <div class="alert alert-danger" role="alert">
                            <h5 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Cảnh báo!</h5>
                            <p>Bạn có chắc chắn muốn xóa menu này không?</p>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">ID:</label>
                            <div class="col-sm-9">
                                <p class="form-control-static">@Model.AdminMenuID</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Tên menu:</label>
                            <div class="col-sm-9">
                                <p class="form-control-static">@Model.ItemName</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Controller:</label>
                            <div class="col-sm-9">
                                <p class="form-control-static">@Model.ControllerName</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Action:</label>
                            <div class="col-sm-9">
                                <p class="form-control-static">@Model.ActionName</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Area:</label>
                            <div class="col-sm-9">
                                <p class="form-control-static">@Model.AreaName</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Thứ tự:</label>
                            <div class="col-sm-9">
                                <p class="form-control-static">@Model.ItemOrder</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Trạng thái:</label>
                            <div class="col-sm-9">
                                <p class="form-control-static">
                                    @if (Model.IsActive == true)
                                    {
                                        <span class="badge bg-success">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Không hoạt động</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <form asp-area="Admin" asp-controller="Menu" asp-action="Delete" method="post">
                            <input type="hidden" asp-for="AdminMenuID" />
                            <div class="row mb-3">
                                <div class="col-sm-12">
                                    <button type="submit" class="btn btn-danger">
                                        <i class="bi bi-trash me-1"></i>Xác nhận xóa
                                    </button>
                                    <a asp-area="Admin" asp-controller="Menu" asp-action="Index" class="btn btn-secondary">
                                        <i class="bi bi-x-circle me-1"></i>Hủy
                                    </a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

