@model TrangChu.Models.Menu

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<main id="main" class="main">
    <div class="pagetitle">
        <h2>Confirm to delete a menu</h2>
    </div>
    <div class="form-row">
        <div class="form-group col-md-6">
            <label asp-for="ID">MenuID</label>
            <input type="text" class="form-control mb-3" asp-for="ID" disabled />
        </div>
        <div class="form-group col-md-6">
            <label asp-for="Name">MenuName</label>
            <input type="text" class="form-control mb-3" asp-for="Name" disabled />
        </div>
    </div>
    <!-- Begin Form --->
    <form asp-area="Admin" asp-controller="Menu" asp-action="Delete" method="Post">
        <input type="hidden" asp-for="ID" />
        <a href="javascript:history.back()" class="btn btn-lg btn-warning p-2 mr-5">
            <i class="bi bi-arrow-left-circle"></i> Go back
        </a>
        <button type="submit" class="btn btn-lg btn-danger p-2">
            <i class="bi bi-trash"></i> Delete
        </button>
    </form>
    <!-- End Form -->
</main>

